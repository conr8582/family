# Copy this to .env and fill in values. Never commit .env to git.

# Server
PORT=3000
NODE_ENV=development

# Auth — use `npm run hash-password` to generate APP_PASSWORD_HASH
APP_USERNAME=barry
APP_PASSWORD_HASH=

# Session — generate a random string, e.g.: openssl rand -hex 32
SESSION_SECRET=

# SimpleFIN
# Your SimpleFIN setup token (one-time claim URL from simplefin.org)
# After the first run this is exchanged for an access URL stored in the DB.
# If you need to re-claim, clear the simplefin_access_url row and set this again.
SIMPLEFIN_SETUP_TOKEN=

# Sync schedule (24h format hour, server local time)
SYNC_HOUR=6

# Database path (relative to project root inside the container)
DB_PATH=./data/finance.db
