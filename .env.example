# Copy this to .env and fill in values. Never commit .env to git.

# Server
PORT=3000
NODE_ENV=development

# Auth — use `npm run hash-password` to generate APP_PASSWORD_HASH
APP_USERNAME=barry
APP_PASSWORD_HASH=

# Session — generate a random string, e.g.: openssl rand -hex 32
SESSION_SECRET=

# SimpleFIN
# Your SimpleFIN setup token (one-time claim URL from simplefin.org)
# After the first run this is exchanged for an access URL stored in the DB.
# If you need to re-claim, clear the simplefin_access_url row and set this again.
SIMPLEFIN_SETUP_TOKEN=

# Sync schedule (24h format hour, server local time)
SYNC_HOUR=6

# Database path (relative to project root inside the container)
DB_PATH=./data/finance.db

# Anthropic API (optional) — enables "What is this?" merchant lookup on the review screen
# Get a key at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Gmail integration (optional) — enables auto-enriching Amazon transactions with item details
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add your redirect URI to the "Authorized redirect URIs" list
# 4. After filling these in, visit /setup/gmail in the app to authorize (one-time)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# For local dev: http://localhost:3000/setup/gmail/callback
# For production: https://yourdomain.com/setup/gmail/callback
GOOGLE_REDIRECT_URI=
