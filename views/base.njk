<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or 'Finance' }}</title>
  <link rel="icon" href="/dog.jpg" type="image/jpeg">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <div class="inner">
      <a href="/" class="brand"><img src="/dog.jpg" alt="Finance" class="nav-dog"></a>
      <a href="/"              class="{{ 'active' if activePage === 'review' }}">Review</a>
      <a href="/budget"        class="{{ 'active' if activePage === 'budget' }}">Budget</a>
      <a href="/filed"         class="{{ 'active' if activePage === 'filed' }}">Filed</a>
      <a href="/reimbursements" class="{{ 'active' if activePage === 'reimbursements' }}">Reimb.</a>
      <div class="spacer"></div>
      <span class="sync-status" id="syncStatus"></span>
      <button class="btn sync-btn" id="syncBtn">Sync</button>
      <form method="POST" action="/logout" style="display:inline">
        <button class="btn">Sign out</button>
      </form>
    </div>
  </nav>
  <div class="container">
    {% block content %}{% endblock %}
  </div>
  <script src="/app.js"></script>
</body>
</html>
