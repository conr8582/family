{% extends "base.njk" %}

{% block content %}

<script>
window.CATEGORIES = {{ categoriesFlat | dump | safe }};
</script>

<div class="review-header">
  <h1>
    Filed
    <span class="badge" style="background: var(--muted)" id="filedCount">{{ total }}</span>
  </h1>
</div>

{% if total > 0 %}
<div class="filed-search-wrap">
  <input
    type="search"
    id="filedSearch"
    class="filed-search"
    placeholder="Search transactions…"
    autocomplete="off"
    autofocus
  >
  <select id="filedCategoryFilter" class="filed-category-filter" aria-label="Filter by category">
    <option value="">All categories</option>
    {% for c in categoriesFlat %}
    <option value="{{ c.id }}">{{ c.name }}</option>
    {% endfor %}
  </select>
</div>
{% endif %}

{% if total === 0 %}
  <div class="empty-state"><p>No filed transactions yet.</p></div>
{% else %}
  <div id="filedList">
    {% for group in groups %}
    <div class="date-group" data-date="{{ group.date }}">
      <h2 class="date-heading">{{ group.date | formatDate }}</h2>

      {% for tx in group.transactions %}
      <div class="tx-row" id="tx-{{ tx.id }}" data-id="{{ tx.id }}" data-category-id="{{ tx.category_id or '' }}">
        <div class="tx-main">
          <span class="tx-desc">{{ tx.description }}</span>
          <span class="tx-account">{{ tx.account_name | shortAccount }}</span>
          <span class="tx-amount amount {% if tx.amount_cents < 0 %}negative{% else %}positive{% endif %}">
            {{ tx.amount_cents | formatCents }}
          </span>
        </div>
        <div class="tx-controls">

          <div class="combobox">
            <input
              type="text"
              class="tx-category-text"
              placeholder="Category…"
              autocomplete="off"
              aria-label="Category"
              {% if tx.category_id %}data-selected-id="{{ tx.category_id }}"{% endif %}
            >
            <input type="hidden" class="tx-category" value="{{ tx.category_id or '' }}">
            <ul class="combobox-list" hidden></ul>
          </div>

          <div class="amount-field">
            <span class="tx-amount-display"></span>
            <button class="tx-amount-edit-btn" type="button" aria-label="Edit amount">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
            </button>
            <input
              class="tx-amount-input"
              type="number"
              step="0.01"
              value="{{ (tx.amount_cents / 100) | round(2) }}"
              aria-label="Amount"
              hidden
            >
          </div>

          <select class="tx-reimb" name="reimbursable" aria-label="Reimbursable">
            <option value="none"          {% if tx.reimbursable === 'none' %}selected{% endif %}>—</option>
            <option value="reimbursable"  {% if tx.reimbursable === 'reimbursable' %}selected{% endif %}>Reimbursable</option>
            <option value="reimbursement" {% if tx.reimbursable === 'reimbursement' %}selected{% endif %}>Reimbursement</option>
          </select>

          <input
            class="tx-notes"
            type="text"
            name="notes"
            placeholder="Note…"
            value="{{ tx.notes or '' }}"
            aria-label="Notes"
          >

          <button class="btn tx-save" type="button">Save</button>
          <button class="btn tx-reopen" type="button">Re-open</button>
        </div>

        {% if tx.is_atm %}
        <div class="tx-atm-bar">
          <button class="tx-itemize-toggle" type="button">
            {% if tx.remaining_cents > 0 %}
              Itemize · ${{ (tx.remaining_cents / 100) | round(2) }} left
            {% else %}
              &#10003; Fully itemized
            {% endif %}
          </button>
        </div>
        <div class="tx-itemize-panel" hidden>
          {% if tx.splits.length > 0 %}
          <div class="itemize-splits">
            {% for s in tx.splits %}
            <div class="itemize-split-row" data-split-id="{{ s.id }}">
              <span class="itemize-split-cat">{{ s.category_name }}</span>
              <span class="itemize-split-amt">${{ (s.amount_cents / 100) | round(2) }}</span>
              {% if s.notes %}<span class="itemize-split-note">{{ s.notes }}</span>{% endif %}
              <button class="itemize-split-remove" type="button" data-split-id="{{ s.id }}" title="Remove">&#215;</button>
            </div>
            {% endfor %}
          </div>
          {% endif %}

          {% if tx.remaining_cents > 0 %}
          <div class="itemize-add-row" data-transaction-id="{{ tx.id }}">
            <div class="combobox itemize-combobox">
              <input type="text" class="tx-category-text" placeholder="Category…" autocomplete="off">
              <input type="hidden" class="tx-category">
              <ul class="combobox-list" hidden></ul>
            </div>
            <input type="number" step="0.01" class="itemize-amount-input" placeholder="Amount" max="{{ (tx.remaining_cents / 100) | round(2) }}">
            <input type="text" class="itemize-notes-input" placeholder="Note (optional)…">
            <button class="btn itemize-add-btn" type="button">Add</button>
            <span class="itemize-error" hidden></span>
          </div>
          {% endif %}
        </div>
        {% endif %}

        {% if tx.is_income_source %}
        <div class="tx-atm-bar">
          <button class="tx-offset-toggle{% if tx.offsets.length > 0 %} tx-offset-toggle--active{% endif %}" type="button">
            {% if tx.offsets.length > 0 %}
              ${{ ((tx.amount_cents - tx.remaining_cents) / 100) | round(2) }} applied to {{ tx.offsets.length }} expense{{ 's' if tx.offsets.length != 1 }}
            {% else %}
              Apply to expense…
            {% endif %}
          </button>
        </div>
        <div class="tx-itemize-panel" hidden>
          {% if tx.offsets.length > 0 %}
          <div class="itemize-splits">
            {% for o in tx.offsets %}
            <div class="itemize-split-row" data-offset-id="{{ o.id }}">
              <span class="itemize-split-cat">{{ o.expense_description }} ({{ o.expense_date | formatDate }})</span>
              <span class="itemize-split-amt">${{ (o.amount_cents / 100) | round(2) }}</span>
              {% if o.notes %}<span class="itemize-split-note">{{ o.notes }}</span>{% endif %}
              <button class="offset-remove" type="button" data-offset-id="{{ o.id }}" title="Remove">&#215;</button>
            </div>
            {% endfor %}
          </div>
          {% endif %}

          {% if tx.remaining_cents > 0 %}
          <div class="offset-add-row" data-transaction-id="{{ tx.id }}">
            <div class="offset-expense-search">
              <input type="text" class="offset-expense-text" placeholder="Search expense to offset…" autocomplete="off">
              <input type="hidden" class="offset-expense-id">
              <ul class="offset-expense-list" hidden></ul>
            </div>
            <input type="number" step="0.01" class="itemize-amount-input" placeholder="Amount" max="{{ (tx.remaining_cents / 100) | round(2) }}">
            <input type="text" class="itemize-notes-input" placeholder="Note (optional)…">
            <button class="btn offset-add-btn" type="button">Add</button>
            <span class="itemize-error" hidden></span>
          </div>
          {% endif %}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>
{% endif %}
{% endblock %}
