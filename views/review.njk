{% extends "base.njk" %}

{% block content %}

{# One shared categories array read by the combobox JS #}
<script>
window.CATEGORIES = {{ categoriesFlat | dump | safe }};
</script>

{% if showNavanReminder %}
<div class="navan-reminder">
  End of {{ reminderMonth }}: <a href="/reimbursements">upload your Navan report</a> to reconcile reimbursements
</div>
{% endif %}

<div class="review-header">
  <h1>
    Review
    {% if total > 0 %}
      <span class="badge" id="reviewCount">{{ total }}</span>
    {% endif %}
  </h1>
</div>

{% if total === 0 %}
  <div class="empty-state">
    <p>You're up to date.</p>
  </div>

{% else %}
  <div id="reviewList">
    {% for group in groups %}
    <div class="date-group" data-date="{{ group.date }}">
      <h2 class="date-heading">{{ group.date | formatDate }}</h2>

      {% for tx in group.transactions %}
      <div class="tx-row" id="tx-{{ tx.id }}" data-id="{{ tx.id }}">
        <div class="tx-main">
          <span class="tx-desc">{{ tx.description }}</span>
          <button class="tx-lookup-btn" type="button" title="What is this charge?" aria-label="Look up merchant">?</button>
          <span class="tx-account">{{ tx.account_name | shortAccount }}</span>
          <span class="tx-amount amount {% if tx.amount_cents < 0 %}negative{% else %}positive{% endif %}">
            {{ tx.amount_cents | formatCents }}
          </span>
        </div>
        <div class="tx-lookup-result" hidden></div>
        {% if tx.suggested_category_id %}
        <div class="tx-suggested-badge" title="Matches the {{ tx.suggested_date_display }} charge — confirm and hit Done to save">
          &#10022; Suggested from {{ tx.suggested_date_display }}
        </div>
        {% endif %}
        <div class="tx-controls">

          {# Category combobox #}
          <div class="combobox{% if tx.suggested_category_id %} combobox--suggested{% endif %}">
            <input
              type="text"
              class="tx-category-text"
              placeholder="Category…"
              autocomplete="off"
              aria-label="Category"
              {% if tx.category_id %}data-selected-id="{{ tx.category_id }}"
              {% elif tx.suggested_category_id %}data-selected-id="{{ tx.suggested_category_id }}"{% endif %}
            >
            <input type="hidden" class="tx-category" value="{{ tx.category_id or tx.suggested_category_id or '' }}">
            <ul class="combobox-list" hidden></ul>
          </div>

          <div class="amount-field">
            <span class="tx-amount-display"></span>
            <button class="tx-amount-edit-btn" type="button" aria-label="Edit amount">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
            </button>
            <input
              class="tx-amount-input"
              type="number"
              step="0.01"
              value="{{ (tx.amount_cents / 100) | round(2) }}"
              aria-label="Amount"
              hidden
            >
          </div>

          <select class="tx-reimb" name="reimbursable" aria-label="Reimbursable">
            <option value="none"          {% if tx.reimbursable === 'none' %}selected{% endif %}>—</option>
            <option value="reimbursable"  {% if tx.reimbursable === 'reimbursable' %}selected{% endif %}>Reimbursable</option>
            <option value="reimbursement" {% if tx.reimbursable === 'reimbursement' %}selected{% endif %}>Reimbursement</option>
          </select>

          <input
            class="tx-notes{% if tx.suggested_notes and not tx.notes %} tx-notes--suggested{% endif %}"
            type="text"
            name="notes"
            placeholder="Note…"
            value="{{ tx.notes or tx.suggested_notes or '' }}"
            aria-label="Notes"
          >

          <button class="btn btn-primary tx-done" type="button">Done</button>
        </div>
      </div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>
{% endif %}
{% endblock %}
