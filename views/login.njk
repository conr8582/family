<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign in — Finance</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <main class="login-wrap">
    <div class="login-card">
      <img src="/dog.jpg" alt="" class="login-dog">
      <h1>Finance</h1>

      {% if error %}
        <p class="login-error">{{ error }}</p>
      {% endif %}

      <form method="POST" action="/login" autocomplete="on">
        <div class="field">
          <label for="username">Username</label>
          <input
            id="username"
            name="username"
            type="text"
            autocomplete="username"
            autofocus
            required
          >
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
          >
        </div>
        <button type="submit" class="btn btn-primary login-btn">Sign in</button>
      </form>
    </div>
  </main>
  <style>
    body { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-wrap { width: 100%; max-width: 360px; padding: 0 24px; }
    .login-dog { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; object-position: center top; display: block; margin: 0 auto 16px; }
    .login-card h1 { margin-bottom: 28px; font-size: 1.25rem; }
    .field { margin-bottom: 14px; }
    .field label { display: block; font-size: 0.8125rem; color: var(--muted); margin-bottom: 5px; }
    .field input { width: 100%; }
    .login-btn { width: 100%; justify-content: center; margin-top: 8px; padding: 10px; }
    .login-error { font-size: 0.875rem; color: var(--red); margin-bottom: 16px; }
  </style>
</body>
</html>
