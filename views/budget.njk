{% extends "base.njk" %}

{% block content %}
<script>
window.BUDGET_VIEW = "{{ view }}";
window.BUDGET_MONTH = "{{ monthStr or '' }}";
window.BUDGET_YEAR = "{{ yearStr or '' }}";
</script>
<div class="budget-header">
  {% if view === 'year' %}
  <div class="month-nav">
    <a href="/budget?view=year&year={{ prevYear }}" class="month-arrow" aria-label="Previous year">&#8592;</a>
    <h1>{{ periodLabel }}</h1>
    {% if isCurrentYear %}
      <span class="month-arrow disabled" aria-hidden="true">&#8594;</span>
    {% else %}
      <a href="/budget?view=year&year={{ nextYear }}" class="month-arrow" aria-label="Next year">&#8594;</a>
    {% endif %}
  </div>
  {% if isCurrentYear %}
  <p class="budget-subcaption">Line items below are budgeted through {{ monthsElapsedLabel }} ({{ monthsElapsed }} of 12 months) — not the full year.</p>
  {% endif %}
  {% else %}
  <div class="month-nav">
    <a href="/budget?view=month&month={{ prevMonth }}" class="month-arrow" aria-label="Previous month">&#8592;</a>
    <h1>
      <select id="monthSelect" class="month-select" aria-label="Select month">
        {% for opt in monthOptions %}
        <option value="{{ opt.value }}" {% if opt.value === monthStr %}selected{% endif %}>{{ opt.label }}</option>
        {% endfor %}
      </select>
    </h1>
    {% if isCurrentMonth %}
      <span class="month-arrow disabled" aria-hidden="true">&#8594;</span>
    {% else %}
      <a href="/budget?view=month&month={{ nextMonth }}" class="month-arrow" aria-label="Next month">&#8594;</a>
    {% endif %}
  </div>
  {% endif %}

  <div class="view-tabs">
    <a href="/budget?view=month" class="view-tab{% if view !== 'year' %} active{% endif %}">Month</a>
    <a href="/budget?view=year{% if yearNum %}&year={{ yearNum }}{% endif %}" class="view-tab{% if view === 'year' %} active{% endif %}">Year</a>
  </div>
</div>

{% if unreviewedCount > 0 %}
<div class="unreviewed-banner">
  <a href="/">{{ unreviewedCount }} unreviewed transaction{{ 's' if unreviewedCount !== 1 }} not yet included in these totals →</a>
</div>
{% endif %}

{# ── At-a-glance summary — actuals only, no budget math ─────────────── #}
<section class="budget-glance">
  <div class="glance-stat">
    <span class="glance-label">Total Income</span>
    <span class="glance-value">{{ totalIncomeActual | formatCentsPlain }}</span>
  </div>
  <div class="glance-stat">
    <span class="glance-label">Total Expenses</span>
    <span class="glance-value">{{ totalExpenseActual | formatCentsPlain }}</span>
  </div>
  <div class="glance-stat glance-stat--net">
    <span class="glance-label">Net Income</span>
    <span class="glance-value {{ 'over' if netActual < 0 }}">{{ netActual | formatVariance }}</span>
  </div>
</section>

{# ── Income ──────────────────────────────────────────────── #}
<section class="budget-section">
  <h2 class="section-heading">Income</h2>
  <table class="budget-table">
    <thead>
      <tr>
        <th>Category</th>
        <th class="num">Budget</th>
        <th class="num">Actual</th>
        <th class="num">Variance</th>
      </tr>
    </thead>
    <tbody>
      {% for r in income %}
      <tr class="budget-row {{ 'zero-row' if r.actual_cents === 0 and r.budget_cents === 0 }}" data-category-id="{{ r.id }}">
        <td><span class="row-toggle">›</span> {{ r.name }}</td>
        <td class="num">{{ r.budget_cents | formatCentsPlain }}</td>
        <td class="num">{{ r.actual_cents | formatCentsPlain }}</td>
        <td class="num {{ 'over' if r.variance_cents < 0 }}">{{ r.variance_cents | formatVariance }}</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr class="section-total">
        <td>Total Income</td>
        <td class="num">{{ totalIncomeBudget | formatCentsPlain }}</td>
        <td class="num">{{ totalIncomeActual | formatCentsPlain }}</td>
        <td class="num {{ 'over' if (totalIncomeActual - totalIncomeBudget) < 0 }}">
          {{ (totalIncomeActual - totalIncomeBudget) | formatVariance }}
        </td>
      </tr>
    </tfoot>
  </table>
</section>

{# ── Expenses ────────────────────────────────────────────── #}
<section class="budget-section">
  <h2 class="section-heading">Expenses</h2>
  <table class="budget-table">
    <thead>
      <tr>
        <th>Category</th>
        <th class="num">Budget</th>
        <th class="num">Actual</th>
        <th class="num">Variance</th>
      </tr>
    </thead>
    <tbody>
      {% for r in expenses %}
      <tr class="budget-row {{ 'zero-row' if r.actual_cents === 0 and r.budget_cents === 0 }}" data-category-id="{{ r.id }}">
        <td>
          <span class="row-toggle">›</span> {{ r.name }}
          {% if r.pct !== null %}
          <div class="progress-bar">
            <div class="progress-fill {{ 'over-budget' if r.pct > 100 }}"
                 style="width: {{ [r.pct, 100] | min }}%"></div>
          </div>
          {% endif %}
        </td>
        <td class="num">{{ r.budget_cents | formatCentsPlain }}</td>
        <td class="num">
          {{ r.actual_cents | formatCentsPlain }}
        </td>
        <td class="num {{ 'over' if r.variance_cents < 0 }}">{{ r.variance_cents | formatVariance }}</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr class="section-total">
        <td>Total Expenses</td>
        <td class="num">{{ totalExpenseBudget | formatCentsPlain }}</td>
        <td class="num">{{ totalExpenseActual | formatCentsPlain }}</td>
        <td class="num {{ 'over' if (totalExpenseBudget - totalExpenseActual) < 0 }}">
          {{ (totalExpenseBudget - totalExpenseActual) | formatVariance }}
        </td>
      </tr>
    </tfoot>
  </table>
</section>

{# ── Net ─────────────────────────────────────────────────── #}
<section class="budget-section net-section">
  <table class="budget-table">
    <tbody>
      <tr class="net-row">
        <td>Net (Income − Expenses)</td>
        <td class="num">{{ netBudget | formatCentsPlain }}</td>
        <td class="num">{{ netActual | formatCentsPlain }}</td>
        <td class="num {{ 'over' if netActual < 0 }}">{{ (netActual - netBudget) | formatVariance }}</td>
      </tr>
    </tbody>
  </table>
</section>

{% endblock %}
